# Anthropic API
ANTHROPIC_API_KEY=sk-ant-...

# Bluesky credentials
BLUESKY_HANDLE=your-handle.bsky.social
BLUESKY_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Agent settings — two-tier model setup
MODEL=claude-sonnet-4-20250514
MODEL_DEEP=claude-opus-4-20250514
DRY_RUN=true
LOG_LEVEL=info
# Enable web search and topics system in ruminate/iterate (requires Anthropic web search access)
WEB_SEARCH=false
